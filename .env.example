# DigitalOcean Deployment Environment Variables Example

# AI Service Keys
GEMINI_API_KEY=your_gemini_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here

# Frontend Settings (Vercel URL once deployed)
FRONTEND_URL=https://newsmind-frontend.vercel.app
CORS_ORIGIN=https://newsmind-frontend.vercel.app

# JWT Secrets for Backend Auth
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
